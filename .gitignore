# Local config & secrets (never commit)
config.json

# Generated data (projects, databases, logs, temp)
data/projects/
data/temp/
data/outputs/
data/logs/
data/*.db

# Ignore large downloaded models in data/models/
data/models/*

# EXCEPTIONS: Track custom cloned voice samples (.wav files) in Git
!data/models/voxcpm/
!data/models/voxcpm/*.wav

# Python caches and virtual environments
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# IDE configs and System files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
